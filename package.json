{
  "name": "code-bhau-agent",
  "private": true,
  "version": "0.1.0",
  "description": "Code Bhau Agent — beginner-friendly AI coding agent. Forked from continuedev/continue under Apache-2.0.",
  "license": "Apache-2.0",
  "author": "Continue Dev, Inc (original); Code Bhau contributors (fork)",
  "type": "module",
  "engines": {
    "node": ">=20.20.1"
  },
  "engine-strict": true,
  "workspaces": [
    "packages/terminal-security",
    "core",
    "gui",
    "extensions/vscode"
  ],
  "scripts": {
    "clean": "rimraf \"./**/node_modules\" \"./**/dist\" \"./**/out\" \"./**/build\" 2>/dev/null || true",
    "build:stub": "npm run build --workspace @continuedev/terminal-security",
    "build:core": "npm run build --workspace core",
    "build:gui": "npm run build --workspace gui",
    "build:vscode": "npm run esbuild --workspace code-bhau",
    "build": "npm run build:stub && npm run build:gui && npm run build:vscode",
    "build:all": "npm run build:stub && npm run build:core && npm run build:gui && npm run build:vscode",
    "tsc:check": "npm run tsc:check --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "package:vscode": "cd extensions/vscode && vsce package"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.6.3"
  }
}
